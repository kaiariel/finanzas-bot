TELEGRAM_BOT_TOKEN=pon_aqui_el_token_de_botfather

# Opcional, pero recomendado. Para varios usuarios, separa IDs con comas.
# Ejemplo: ALLOWED_TELEGRAM_USER_IDS=11111111,22222222,33333333
# Cada usuario debe enviar /start al bot para ver su ID.
ALLOWED_TELEGRAM_USER_IDS=

# Opcional: nombres visibles para reporte/estado. Formato id:nombre separado por comas.
# Ejemplo: TELEGRAM_USER_NAMES=11111111:Ariel,22222222:Maria
TELEGRAM_USER_NAMES=

# Datos locales
DATA_DIR=data
SQLITE_DB_PATH=data/finances.db
EXPORT_CSV_PATH=data/movimientos.csv
REPORT_HTML_PATH=reports/finanzas.html
TIMEZONE=Europe/Madrid

# Carpeta local sincronizada por Google Drive para escritorio.
# Ejemplos:
# RECEIPTS_SYNC_DIR=G:\Mi unidad\Finanzas - Tickets
# RECEIPTS_SYNC_DIR=C:\Users\TuUsuario\Google Drive\Mi unidad\Finanzas - Tickets
RECEIPTS_SYNC_DIR=data/receipts
VOICES_SYNC_DIR=data/voices

# Opcional: transcripcion local de notas de voz, sin API de pago.
# Requiere: pip install -r requirements-voice.txt
VOICE_TRANSCRIPTION_ENABLED=0
VOICE_TRANSCRIPTION_MODEL=base
VOICE_TRANSCRIPTION_DEVICE=cpu
VOICE_TRANSCRIPTION_COMPUTE_TYPE=int8

# Opcional: ruta al ejecutable de Tesseract si no queda en PATH.
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
TESSERACT_CMD=
